{
    "name": "vigihdevwp/events",
    "description": "WordPress events library for WordPress development.",
    "keywords": [
        "wordpress",
        "events",
        "framework"
    ],
    "type": "library",
    "license": "MIT",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "authors": [
        {
            "name": "Vigih Dev",
            "email": "vigihdevwp@gmail.com",
            "role": "developer"
        }
    ],
    "autoload": {
        "psr-4": {
            "VigihdevWP\\Events\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "VigihdevWP\\Events\\Tests\\": "tests/"
        }
    },
    "config": {
        "process-timeout": 0
    },
    "scripts": {
        "test": "phpunit",
        "dev": "php -S localhost:2092 local-dev/index.php"
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://satiswp.id"
        }
    ],
    "require": {
        "php": "^8.1",
        "symfony/serializer": "^6.4"
    },
    "require-dev": {
        "phpunit/phpunit": "10.5.x-dev"
    }
}